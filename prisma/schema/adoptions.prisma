// Module: adoptions (M04) · Owner: @fabian
//
// T-028a — solicitud de adopción + evaluación. Dato de negocio tenant-scoped:
// lleva organization_id (org dueña del animal) y está protegido por Row-Level
// Security (RLS ENABLE+FORCE + tenant_isolation), como el patrón _rls_probe.
//
// FRONTERAS:
//   - NO se declara la relación Prisma con `Organization` (org.prisma, de
//     @sebastian) ni con `Animal` (animals.prisma, de @sebastian): el animal se
//     referencia por `animalId` (uuid) y su snapshot; la FK a organizations +
//     ON DELETE CASCADE se añade a mano en el SQL de la migración (igual que la
//     RLS, que Prisma no modela). Así M04 no toca los esquemas de M01/M03.
//   - La creación por una persona que NO pertenece a la org destino necesita
//     escribir en otro tenant sin evadir RLS: se hace vía la función
//     `create_adoption_request(...)` SECURITY DEFINER de la migración.

/// Estados: new → in_review → approved | rejected (contrato AdoptionStatus).
model AdoptionRequest {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  /// Referencia al animal en M03 (sin FK cross-módulo).
  animalId        String   @map("animal_id") @db.Uuid
  /// Snapshot mínimo del animal (AdoptionAnimalSnapshot); fuente de verdad = M03.
  animalSnapshot  Json     @map("animal_snapshot")
  /// Persona autenticada que postuló (fijado por el backend desde el JWT).
  applicantUserId String   @map("applicant_user_id") @db.Uuid
  /// Contacto del solicitante (AdoptionApplicant; dato personal Ley 1581).
  applicant       Json
  message         String
  /// AdoptionStatus como texto (sin enum en runtime; ver nota CJS del contrato).
  status          String   @default("new")
  /// Puntos de integración tipados (T-028b / T-028c); nulos en este corte.
  contractRef     String?  @map("contract_ref")
  trackingRef     String?  @map("tracking_ref")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([animalId])
  @@index([applicantUserId])
  @@map("adoption_requests")
}

/// T-028b — CONTRATO de adopción (RF11) generado tras aprobar una solicitud.
/// Dato de negocio tenant-scoped: lleva organization_id (org dueña del animal) y
/// RLS ENABLE+FORCE + tenant_isolation, como adoption_requests.
///
/// Estados: draft → pending_signatures → signed (TERMINAL, inmutable) ; cancel
/// desde draft/pending. Firmantes DINÁMICOS y sus firmas viven en `signers` (Json).
/// Al completarse todas las firmas se calcula el hash SHA-256 del `payload`
/// canónico y se sella (`content_hash` + `signed_at`), quedando INMUTABLE — además
/// del trigger `adoption_contract_freeze` que aborta UPDATE/DELETE de filas signed
/// para CUALQUIER rol (RNF05, versionamiento documental).
///
/// FRONTERAS: sin relaciones Prisma con org.prisma/animals.prisma (de @sebastian);
/// las FK a organizations y a adoption_requests + ON DELETE CASCADE se añaden a
/// mano en el SQL de la migración (igual que la RLS). La firma del ADOPTANTE, que
/// es cross-tenant, se aplica vía funciones SECURITY DEFINER de la migración.
model AdoptionContract {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  /// Solicitud aprobada que originó el contrato (seam contractRef de T-028a).
  requestId      String   @map("request_id") @db.Uuid
  /// Referencia al animal en M03 (sin FK cross-módulo).
  animalId       String   @map("animal_id") @db.Uuid
  /// Versión documental (RNF05); 1 en el primer corte.
  version        Int      @default(1)
  /// AdoptionContractStatus como texto (sin enum en runtime; nota CJS del contrato).
  status         String   @default("draft")
  /// Firmantes dinámicos + estado de cada firma (AdoptionContractSigner[]).
  signers        Json
  /// Contenido canónico versionable (AdoptionContractPayload); fuente del hash.
  payload        Json
  /// SHA-256 hex del payload canónico; NULL hasta el sellado (signed).
  contentHash    String?  @map("content_hash")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  /// UTC del sellado (NULL hasta signed).
  signedAt       DateTime? @map("signed_at")

  @@unique([requestId, version])
  @@index([organizationId])
  @@index([status])
  @@map("adoption_contracts")
}
