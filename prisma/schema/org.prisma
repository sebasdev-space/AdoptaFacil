// Module: org (tenant foundation) · Owner: @sebastian (Ola 0)
// Ships the minimal tenant anchor and the canonical RLS reference table.

/// Global tenant registry. Intentionally NOT under RLS — it is the platform-level
/// catalog of organizations. Every future business table carries organization_id
/// referencing this table and MUST enable RLS (see _rls_probe as the reference).
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members                  OrgMember[]
  users                    User[]
  roleAssignments          UserRole[]
  auditLogs                AuditLog[]
  profile                  OrganizationProfile?
  formalizationTransitions FormalizationTransition[]
  documents                OrganizationDocument[]

  @@map("organizations")
}

/// Append-only history of formalization state changes (M01, RF02). Tenant-scoped
/// (RLS ENABLE+FORCE + tenant_isolation) AND immutable: the T-102 migration
/// grants the app role only SELECT+INSERT and installs triggers that reject any
/// UPDATE/DELETE/TRUNCATE — the business record of every transition, kept
/// forever. `created_at` is UTC. The current state itself lives on
/// organization_profiles.formalization_state; this table is its audit trail.
model FormalizationTransition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  fromState      String   @map("from_state")
  toState        String   @map("to_state")
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@map("formalization_transitions")
}

/// Organization institutional PROFILE (M01, §14). Tenant-scoped business data:
/// carries organization_id and is protected by Row-Level Security (RLS
/// ENABLE+FORCE + tenant_isolation), so an org only ever reads/edits its own
/// profile. The PUBLIC portal view does NOT read this table directly — it goes
/// through the `organization_public(slug)` SECURITY DEFINER function, which
/// returns only public columns (so RLS is never evaded by a raw select). One
/// profile per organization (1:1).
model OrganizationProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  organizationId     String   @unique @map("organization_id") @db.Uuid
  nit                String?
  legalName          String?  @map("legal_name")
  description        String?
  logoUrl            String?  @map("logo_url")
  coverPhotos        String[] @map("cover_photos")
  whatsapp           String?
  contactEmail       String?  @map("contact_email")
  phone              String?
  /// { country, department, city, address } — OrganizationLocation contract.
  location           Json?
  /// { instagram, facebook, tiktok, website } — OrganizationSocialLinks.
  socialLinks        Json?    @map("social_links")
  subdomain          String?  @unique
  slug               String?  @unique
  formalizationState String   @default("informal") @map("formalization_state")
  rteVigente         Boolean  @default(false) @map("rte_vigente")
  /// { level, label?, criteria[] } — VerificationLevel contract.
  verificationLevel  Json?    @map("verification_level")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_profiles")
}

/// Versioned organization DOCUMENTS (M01, RF03, §9/§10/§14, RNF05). Tenant-scoped
/// business data: carries organization_id, RLS ENABLE+FORCE + tenant_isolation,
/// so an org only ever reads/inserts its OWN documents. The app role gets only
/// SELECT+INSERT — a new upload of the same `type` is a NEW row (next `version`);
/// older versions are never overwritten (history kept forever). The single review
/// decision (Pending/UnderReview → Observed|Approved|Rejected) is applied by the
/// `platform_document_decide()` SECURITY DEFINER function (cross-tenant platform
/// review), and DB triggers then FREEZE the row: any UPDATE after a decision and
/// any DELETE/TRUNCATE are rejected for EVERY role (review metadata immutable,
/// RNF05). Expiry is NOT stored: `expiresAt < now` on an Approved doc is presented
/// as Expired at read time. `created_at`/`expires_at`/… are UTC.
model OrganizationDocument {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  type             String
  storageRef       String    @map("storage_ref")
  version          Int
  issuedAt         DateTime? @map("issued_at")
  expiresAt        DateTime? @map("expires_at")
  status           String    @default("pending")
  reviewNote       String?   @map("review_note")
  reviewedByUserId String?   @map("reviewed_by_user_id") @db.Uuid
  reviewedAt       DateTime? @map("reviewed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, version])
  @@index([organizationId])
  @@index([status])
  @@map("organization_documents")
}

/// Append-only audit log (RNF04, §8/§14). Immutable: the T-013 migration ENABLEs
/// + FORCEs RLS (tenant_isolation), grants the app role only SELECT+INSERT, and
/// installs BEFORE UPDATE/DELETE/TRUNCATE triggers that reject any mutation —
/// so records cannot be altered even by a privileged role via the normal path.
/// `created_at` is UTC (retention is computed from it; no purge job in Ola 0).
/// Never store secrets in `metadata` (passwords, tokens…); AuditService redacts
/// known-sensitive keys as a defense. Kept in org.prisma (owned by @sebastian)
/// to avoid an unowned schema file in CODEOWNERS.
model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@map("audit_logs")
}

/// Tenant-scoped user PROFILE (module: M02). Protected by Row-Level Security
/// (RNF03): every row carries organization_id and the T-011 migration ENABLEs +
/// FORCEs RLS with tenant_isolation, so a request only ever sees users of its
/// own organization. Authentication does NOT read this table (see AuthCredential
/// — a global identity index): login happens before any tenant context exists.
model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  accountType    String   @map("account_type")
  email          String
  displayName    String   @map("display_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credential          AuthCredential?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  roleAssignments     UserRole[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

/// RBAC role assignment (§13): a role a user holds WITHIN an organization.
/// Tenant-scoped and protected by Row-Level Security (RLS ENABLE+FORCE), so
/// authority never leaks across organizations — an Administrator of Org A is
/// invisible (and powerless) under Org B's context. Roles are the document-base
/// names; the string mirrors the `Role` enum in @adoptafacil/contracts.
model UserRole {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, role])
  @@index([organizationId])
  @@index([userId])
  @@map("user_roles")
}

/// Global identity/credential index (module: M02). Intentionally NOT under RLS —
/// like `organizations`, it is a platform-level directory: login looks a user up
/// by email BEFORE any tenant context exists. Stores only the password HASH,
/// never the plaintext. Carries organization_id + account_type so tokens can be
/// issued without reading the RLS-protected `users` table.
model AuthCredential {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  accountType    String   @map("account_type")
  email          String   @unique
  passwordHash   String   @map("password_hash")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_credentials")
}

/// Refresh-token store (module: M02) for rotation + revocation. NOT under RLS
/// (auth infrastructure, keyed by user). Only the SHA-256 HASH of the opaque
/// refresh token is stored — never the token itself. Rotation revokes the old
/// row and links it to its replacement for reuse detection.
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Password-reset token store (module: M02). NOT under RLS. Stores only the
/// SHA-256 HASH of the reset token; delivery goes through the simulable
/// NotificationPort. `usedAt` makes tokens single-use.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// First REAL business table (module: org) protected by Row-Level Security
/// (RNF03). Every row carries organization_id; the T-010 migration ENABLEs and
/// FORCEs RLS and adds the tenant_isolation policy + grants to adoptafacil_app.
/// Access it only through PrismaService.withTenant() so app.current_org_id is
/// set for the transaction — RLS then filters automatically and, if the code
/// ever forgets, still yields zero rows.
model OrgMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String
  displayName    String   @map("display_name")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("org_members")
}

/// Canonical Row-Level Security reference — HARNESS ONLY, not a business table.
/// The cross-org no-leak gate (RNF03) runs against this table, and every module
/// owner replicates the same organization_id + RLS pattern for their own tables.
/// RLS policy, FORCE, the app role and grants are added by the initial migration.
model RlsProbe {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  payload        String

  @@map("_rls_probe")
}
