# ==============================================================================
# AdoptaFacil - example environment. Create your .env with:  pnpm setup:env
# (that guarantees UTF-8 without BOM; do NOT use PowerShell `>` / Out-File, which
#  write UTF-16 and make Prisma resolve every variable as "(not available)").
# NEVER commit a real .env; it is git-ignored. These are non-secret dev values.
# The API validates these at startup and refuses to boot if a required var is
# missing or malformed (see apps/api config validation).
# ==============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development

# --- API (apps/api) --------------------------------------------------------
API_PORT=3000
# Comma-separated origins allowed by CORS (the web dev server by default).
API_CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL (consumed by docker-compose AND Prisma) --------------------
POSTGRES_USER=adoptafacil
POSTGRES_PASSWORD=adoptafacil
POSTGRES_DB=adoptafacil
# Host port for the docker container. Defaults to 5433 (not 5432) so it does NOT
# collide with a native PostgreSQL install commonly listening on 5432. The
# container still listens on 5432 internally; docker-compose maps host->5432.
POSTGRES_PORT=5433
# Prisma connection string. Host port must match POSTGRES_PORT above.
# Superuser role from docker-compose; used for migrations and the API.
DATABASE_URL=postgresql://adoptafacil:adoptafacil@localhost:5433/adoptafacil?schema=public
# Non-superuser application role created by the initial migration. Used by the
# RLS no-leak test, because superusers bypass Row-Level Security.
DATABASE_URL_APP=postgresql://adoptafacil_app:adoptafacil_app@localhost:5433/adoptafacil?schema=public

# --- Redis / BullMQ --------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Integration ports (simulable stubs only in Sprint 0) ------------------
# NotificationPort adapter: `log` writes to stdout. No real provider wired.
NOTIFICATION_DRIVER=log

# --- Web (apps/web, Vite) --------------------------------------------------
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
VITE_API_URL=http://localhost:3000
