# ==============================================================================
# AdoptaFácil — example environment.  Copy to `.env` and adjust.
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (PowerShell)
# NEVER commit a real `.env`; it is git-ignored. These are non-secret dev values.
# The API validates these at startup and refuses to boot if any required var
# is missing or malformed (see apps/api config validation).
# ==============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development

# --- API (apps/api) --------------------------------------------------------
API_PORT=3000
# Comma-separated origins allowed by CORS (the web dev server by default).
API_CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL (consumed by docker-compose AND Prisma) --------------------
POSTGRES_USER=adoptafacil
POSTGRES_PASSWORD=adoptafacil
POSTGRES_DB=adoptafacil
POSTGRES_PORT=5432
# Prisma connection string. Must line up with the POSTGRES_* values above.
DATABASE_URL=postgresql://adoptafacil:adoptafacil@localhost:5432/adoptafacil?schema=public

# --- Redis / BullMQ --------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Integration ports (simulable stubs only in Sprint 0) ------------------
# NotificationPort adapter: `log` writes to stdout. No real provider wired.
NOTIFICATION_DRIVER=log

# --- Web (apps/web, Vite) --------------------------------------------------
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
VITE_API_URL=http://localhost:3000
